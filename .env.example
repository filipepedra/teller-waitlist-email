# =========================================================
# HMAC — assinatura do webhook
# Gerar com: openssl rand -hex 32
# Suporta múltiplos secrets separados por vírgula durante rotação
# =========================================================
WAITLIST_EMAIL_HMAC_SECRET=

# =========================================================
# Resend — envio de email transacional
# Key começa com "re_". Pegue em https://resend.com/api-keys
# Em dev, mande do domínio sandbox "onboarding@resend.dev".
# Em prod, verifique useteller.com.br no Resend e use no-reply@useteller.com.br.
# =========================================================
RESEND_API_KEY=
WAITLIST_EMAIL_FROM=
WAITLIST_EMAIL_REPLY_TO=

# =========================================================
# Google Sheet — storage (Fase 2)
# =========================================================
WAITLIST_SHEET_ID=
WAITLIST_SHEET_TAB=waitlist
WAITLIST_SHEET_HEADER_ROW=1
GOOGLE_SERVICE_ACCOUNT_JSON=

# =========================================================
# Simulador local
# =========================================================
SIMULATOR_TARGET_URL=http://localhost:3000
