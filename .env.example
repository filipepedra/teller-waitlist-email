# Neon Postgres connection string
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Resend transactional email
RESEND_API_KEY=re_xxxxxxxxxxxx

# HMAC para validar webhook (gerar com: openssl rand -hex 32)
# Suporta múltiplos secrets separados por vírgula durante rotação
WAITLIST_EMAIL_HMAC_SECRET=

# Remetente
WAITLIST_EMAIL_FROM=Teller <no-reply@useteller.com.br>
WAITLIST_EMAIL_REPLY_TO=oi@useteller.com.br
